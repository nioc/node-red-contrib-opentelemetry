{
	"name": "@frankvdb/node-red-contrib-opentelemetry",
	"version": "1.0.0",
	"description": "Full OpenTelemetry support (tracing, metrics, logs) for Node-RED",
	"scripts": {
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"build": "tsc",
		"prepublishOnly": "npm run build",
		"test": "node --test",
		"test:cov": "node --test --experimental-test-coverage"
	},
	"files": [
		"dist",
		"lib/*.html",
		"lib/icons",
		"README.md",
		"LICENSE.md"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"keywords": [
		"node-red",
		"opentelemetry",
		"tracing",
		"metrics",
		"logs",
		"otel",
		"otlp"
	],
	"contributors": [
		"nioc <dev@nioc.eu>",
		"frankvdb7 <5363672+frankvdb7@users.noreply.github.com>"
	],
	"license": "LGPL-3.0-or-later",
	"homepage": "https://github.com/frankvdb7/node-red-contrib-opentelemetry",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/frankvdb7/node-red-contrib-opentelemetry.git"
	},
	"bugs": "https://github.com/frankvdb7/node-red-contrib-opentelemetry/issues",
	"node-red": {
		"version": ">=4.0.0",
		"nodes": {
			"opentelemetry": "dist/opentelemetry-node.js"
		},
		"plugins": {
			"opentelemetry-runtime": "dist/opentelemetry-node.js"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/jmespath": "^0.15.2",
		"@types/node": "^25.6.0",
		"@types/node-red__registry": "^1.3.11",
		"@types/node-red__util": "^1.3.8",
		"node-red": "^4.1.8",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"node-red": ">=4.0.0"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/api-logs": "^0.214.0",
		"@opentelemetry/core": "^2.6.1",
		"@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
		"@opentelemetry/exporter-logs-otlp-proto": "^0.214.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
		"@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
		"@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
		"@opentelemetry/propagator-b3": "^2.6.1",
		"@opentelemetry/propagator-jaeger": "^2.6.1",
		"@opentelemetry/resources": "^2.6.1",
		"@opentelemetry/sdk-logs": "^0.214.0",
		"@opentelemetry/sdk-metrics": "^2.6.1",
		"@opentelemetry/sdk-trace-base": "^2.6.1",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"jmespath": "^0.16.0",
		"on-finished": "^2.4.1"
	}
}
